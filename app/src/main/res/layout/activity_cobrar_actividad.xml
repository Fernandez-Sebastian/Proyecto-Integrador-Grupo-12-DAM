<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_app">

    <!-- Header azul con título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/azul_principal">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver"
            android:src="@drawable/baseline_arrow_back_24"/>

        <TextView
            android:text="Cobrar actividad"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/blanco"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="80dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="4dp"/>

    </LinearLayout>

    <!-- Contenido central -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Buscar -->
            <TextView
                android:text="Buscar"
                android:textColor="@color/gris_texto"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"

                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="@color/blanco"

                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_search">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="22345678"
                    android:paddingHorizontal="8dp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"

                android:background="@drawable/bg_card"
                android:elevation="2dp">

                <TextView
                    android:text="Detalle"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:text="No Socio Seleccionado"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@drawable/text_view_rounded"
                    android:layout_marginBottom="12dp"/>

                <!-- Actividad -->
                <TextView
                    android:text="Actividad"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Precio -->
                <TextView
                    android:text="Precio"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="$ 00.00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- Métodos de pago -->
                <TextView
                    android:text="Método de pago"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Botón registrar -->
                <Button
                    android:text="Registrar no socio"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="@color/blanco"
                    android:textColor="@color/azul_principal"
                    android:layout_marginBottom="12dp"/>

                <!-- Botón cobrar -->
                <Button
                    android:text="Cobrar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="@color/verde_boton"
                    android:textColor="@color/blanco"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Barra inferior -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/azul_principal"/>

</LinearLayout>