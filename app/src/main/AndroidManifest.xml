        <activity android:name=".activities.CobrarActividad" />

        <activity android:name=".activities.ComprobanteActivity"/>
        <activity android:name=".activities.RegistrarNoSocioActivity"/>
        <activity
            android:name=".activities.LogoutActivity"
            android:exported="false" />
        <activity
            android:name=".activities.MenuActivity"
            android:exported="false" /> <!-- LOGIN (pantalla inicial) -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Podés dejar Main temporalmente o borrarlo después -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
    </application>

</manifest>